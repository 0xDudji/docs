{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "linden",
  "name": "Dudji's Docs",
  "colors": {
    "primary": "#a855f7",
    "light": "#c084fc",
    "dark": "#7e22ce"
  },
  "appearance": {
    "default": "dark",
    "decorations": {
      "background": "grid"
    }
  },
  "background": {
    "decoration": "grid",
    "color": {
      "dark": "#000000"
    }
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "dark": "tokyo-night",
        "light": "github-light"
      }
    }
  },
  "favicon": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "custom": {
    "css": "/custom.css"
  },
  "seo": {
    "indexHiddenPages": false
  },
  "fonts": {
    "body": { "family": "JetBrains Mono" },
    "heading": { "family": "JetBrains Mono" }
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Home",
      "href": "https://Dudji.com"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Overview",
        "groups": [
          {
            "group": "Overview",
            "pages": ["index"]
          }
        ]
      },
      {
        "tab": "Books",
        "url": "academy/books/index",
        "groups": [
          {
            "group": "Overview",
            "pages": ["academy/books/index"]
          },
          {
            "group": "Progress",
            "root": "academy/books/index",
            "pages": [
              "academy/books/currently-reading",
              "academy/books/completed"
            ]
          }
        ]
      },
      {
        "tab": "Certifications",
        "url": "academy/certifications/index",
        "groups": [
          {
            "group": "Certifications",
            "root": "academy/certifications/index",
            "pages": [
              "academy/certifications/in-progress",
              "academy/certifications/achieved"
            ]
          }
        ]
      },
      {
        "tab": "Credly",
        "href": "https://www.credly.com/users/dudji/badges#credly",
        "groups": []
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://dudji.com"
  },
  "footer": {
    "links": [
      {
        "header": "Dudji",
        "items": [
          { "label": "Home", "href": "https://Dudji.com" },
          { "label": "Contact", "href": "https://Dudji.com/contact" },
          { "label": "Hackbook", "href": "https://Hackbook.Dudji.com" },
          { "label": "Writeups", "href": "https://Writeups.Dudji.com" },
          {
            "label": "Credly",
            "href": "https://www.credly.com/users/dudji/badges#credly"
          }
        ]
      },
      {
        "header": "Books",
        "items": [
          {
            "label": "Currently Reading",
            "href": "/academy/books/currently-reading"
          },
          {
            "label": "Completed",
            "href": "/academy/books/completed"
          }
        ]
      },
      {
        "header": "Certifications",
        "items": [
          {
            "label": "In Progress",
            "href": "/academy/certifications/in-progress"
          },
          {
            "label": "Achieved",
            "href": "/academy/certifications/achieved"
          }
        ]
      }
    ],
    "socials": {
      "x": "https://x.com/dudji",
      "linkedin": "https://linkedin.com/in/dudji",
      "instagram": "https://instagram.com/dudji",
      "github": "https://github.com/0xDudji"
    }
  }
}
